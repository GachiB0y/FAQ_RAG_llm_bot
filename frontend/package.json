{
  "name": "cursor-instructions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Starter для документации и инструкций Cursor: React + Vite + Chakra + Zustand + React Query",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,md,scss,json}\" --write",
    "format:check": "prettier \"**/*.{ts,tsx,js,jsx,md,scss,json}\" --check",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "i18n:sync": "node scripts/i18n-sync.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm exec eslint --max-warnings=0 --fix --no-warn-ignored"
    ],
    "*.{ts,tsx,js,jsx,json,md,scss}": [
      "pnpm exec prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.48.0",
    "@typescript-eslint/parser": "8.48.0",
    "@vitejs/plugin-react-swc": "4.2.2",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "fast-glob": "3.3.3",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.7.0",
    "sass": "1.94.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "7.2.4"
  },
  "dependencies": {
    "@chakra-ui/icons": "2.2.6",
    "@chakra-ui/react": "2.8.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@tanstack/react-query": "5.90.11",
    "axios": "1.13.2",
    "clsx": "2.1.1",
    "framer-motion": "12.23.24",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-intl": "7.1.14",
    "react-router-dom": "7.9.6",
    "zustand": "5.0.8"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.23.0"
}
