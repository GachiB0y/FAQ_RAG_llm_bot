# models.env — ЕДИНСТВЕННОЕ место с названиями моделей eval-пула.
# Только слаги моделей (НЕ секрет) → коммитится в git. API-ключи живут в .env.eval / .env.
#
# Правило: меняешь модель — правишь ТОЛЬКО здесь. Читает Makefile (через `include`)
# и прокидывает в скрипты как env. Скрипты своих дефолтов НЕ имеют: нет env → падают
# с внятной ошибкой (никакой тихо подхваченной стухшей модели).
#
# 3 разные семьи (Alibaba / OpenAI / Google) → судья независим от генератора
# (нет self-preference bias). Обоснование и цены: docs/plans/2026-07-08-model-flow.md
# Разовое переопределение (без правки файла): make eval-dense GEN_MODEL=deepseek/deepseek-v4-flash
#
# ВАЖНО: не добавляй inline-комментарии после значений — make заберёт их
# в значение вместе с пробелами. Комментарии только на отдельных строках.

# генератор (Alibaba, хороший русский)
GEN_MODEL=qwen/qwen3.6
# судья (OpenAI, ПОЛНАЯ — не mini!)
JUDGE_MODEL=openai/gpt-5.4
# KG + testset (Google, дёшево, много вызовов)
KG_MODEL=google/gemini-3.1-flash-lite
